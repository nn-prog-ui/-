# ============================================================
# AI FX市場監視システム 環境変数設定
# このファイルをコピーして .env として使用してください
# .env は絶対にGitにコミットしないでください
# ============================================================

# アプリ設定
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# データ設定
DATA_DIR=data/raw
PROCESSED_DIR=data/processed
DB_PATH=data/fx_monitor.db

# 対象通貨ペア
DEFAULT_SYMBOL=USD/JPY
DEFAULT_CSV_FILE=USDJPY_1h.csv

# ============================================================
# 安全ロック設定
# TRADING_MODE は必ず "demo_only" のままにしてください
# "live" に変更することは絶対に禁止します（将来でも）
# ============================================================
TRADING_MODE=demo_only

# ============================================================
# 以下のAPIキーは現時点では使用しません
# 将来の拡張時にのみ設定してください
# コードに直接書かず、必ずここに記述してください
# ============================================================

# OANDA API（デモ口座のみ、将来実装予定）
# OANDA_API_KEY=
# OANDA_ACCOUNT_ID=
# OANDA_ENVIRONMENT=practice

# AIコメント生成API（将来実装予定）
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# 通知設定（将来実装予定）
# LINE_CHANNEL_ACCESS_TOKEN=
# SLACK_WEBHOOK_URL=
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=
# EMAIL_FROM=
# EMAIL_TO=
