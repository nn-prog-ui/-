# ============================================================
# AI FX市場監視システム 環境変数設定
# このファイルをコピーして .env として使用してください
# .env は絶対にGitにコミットしないでください
# ============================================================

# アプリ設定
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# データ設定
DATA_DIR=data/raw
PROCESSED_DIR=data/processed
DB_PATH=data/fx_monitor.db

# 対象通貨ペア
DEFAULT_SYMBOL=USD/JPY
DEFAULT_CSV_FILE=USDJPY_1h.csv

# ============================================================
# データソース設定
# DATA_SOURCE=csv      : CSVファイルから読み込む（デフォルト・安全）
# DATA_SOURCE=yfinance : Yahoo Financeから取得（Phase 84: 口座不要・無料・推奨）
# DATA_SOURCE=oanda    : OANDAデモAPIからリアルタイム取得（Phase 8〜）
#
# 【DMM FX など MT4非対応ブローカー利用者へ】
# DATA_SOURCE=yfinance が最も手軽です。
# pip install yfinance を実行してから DATA_SOURCE=yfinance に変更してください。
# ============================================================
DATA_SOURCE=csv
# DATA_SOURCE=yfinance

# ============================================================
# 安全ロック設定
# TRADING_MODE は必ず "demo_only" のままにしてください
# "live" に変更することは絶対に禁止します（将来でも）
# ============================================================
TRADING_MODE=demo_only

# ============================================================
# OANDA デモAPI設定（DATA_SOURCE=oanda の場合のみ有効）
# 1. OANDA に無料デモ口座を開設: https://www.oanda.com/
# 2. My Account → Manage API Access → Generate API Token
# 3. 必ず OANDA_ENVIRONMENT=practice （デモ口座）のまま使用
#    "live" に変更すると起動時エラーになります（安全ロック）
# ============================================================
# OANDA_API_KEY=your_practice_api_key_here
# OANDA_ACCOUNT_ID=your_account_id_here
# OANDA_ENVIRONMENT=practice

# ============================================================
# 以下のAPIキーは将来の拡張時にのみ設定してください
# ============================================================

# ============================================================
# Claude AI コメント生成（Phase 87: 実接続対応）
# 設定するとAIコメントが本物のClaude AIで生成されます（未設定でもルールベース自動生成で動作します）
#
# 設定手順：
# 1. https://console.anthropic.com/ でアカウントを無料作成
# 2. 「API Keys」ページでキー（sk-ant-xxxxx）を発行
# 3. 下の行のコメント（#）を外してキーを貼り付けてください
# 4. サーバーを再起動する
#
# 設定後は /settings ページの「接続テスト」ボタンで動作確認できます
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-ここにキーを貼り付ける
# CLAUDE_MODEL=claude-haiku-4-5   # 使用するモデル（デフォルト: claude-haiku-4-5）
# OPENAI_API_KEY=

# ============================================================
# Gmail SMTP 通知設定（Phase 9）
# 1. Googleアカウント → セキュリティ → 2段階認証をON
# 2. 「アプリパスワード」を検索 → アプリ名を入力（例: FX通知）→ 作成
# 3. 表示された16文字のパスワードを EMAIL_APP_PASSWORD に設定
# ============================================================
# EMAIL_FROM=your_gmail@gmail.com       # 送信元Gmailアドレス
# EMAIL_APP_PASSWORD=xxxx xxxx xxxx     # Gmailアプリパスワード（16文字）
# EMAIL_TO=your_gmail@gmail.com         # 送信先（自分宛でOK）
# NOTIFY_ON_BUY=true      # BUY判定時に通知
# NOTIFY_ON_SELL=true     # SELL判定時に通知
# NOTIFY_ON_SKIP=false    # SKIP判定時は通知しない
# NOTIFY_MIN_SCORE=0      # 最低スコア（0=全件通知）
# NOTIFY_GEO_ALERT=true   # 地政学リスク強検出時（strong_bullish/strong_bearish）に通知（Phase 71）

# ============================================================
# 定期スキャン設定（Phase 16）
# ============================================================
# SCAN_ENABLED=true           # スキャンの有効/無効（デフォルト: true）
# SCAN_INTERVAL_MINUTES=60    # スキャン間隔（分、デフォルト: 60）

# ============================================================
# HTTP Basic認証設定（Phase 64）
# 両方を設定すると全ページにパスワード保護がかかります
# /health エンドポイントは認証不要（Railway ヘルスチェック用）
# ============================================================
# AUTH_USERNAME=admin
# AUTH_PASSWORD=your_strong_password_here

# ============================================================
# Railway デプロイ設定
# Railwayのダッシュボード → Variables に以下を設定してください
# ============================================================
# APP_ENV=production
# DB_PATH=/app/data/fx_monitor.db   ← Railwayボリュームのパス
# DATA_SOURCE=csv
# TRADING_MODE=demo_only
# ANTHROPIC_API_KEY=your_key_here   ← AI分析機能を使う場合
# AUTH_USERNAME=admin               ← 本番では必ず設定してください
# AUTH_PASSWORD=your_strong_password_here
